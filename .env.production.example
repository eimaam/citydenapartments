# ── Backend (Docker) ──────────────────────────────────
NODE_ENV=production
PORT=3000
MONGODB_URI=mongodb://mongodb:27017/cityden?replicaSet=rs0
JWT_SECRET=change-me-use-openssl-rand-hex-32
JWT_EXPIRES_IN=7d
REDIS_HOST=redis
REDIS_PORT=6379
CORS_ORIGINS=https://staff.citydenapartments.com,https://admin.citydenapartments.com

# ── Frontend (Cloudflare Pages build-time env vars) ───
# Set these in Cloudflare Dashboard → Settings → Environment Variables
# Platform (staff.citydenapartments.com):
#   VITE_API_BASE_URL=https://api.citydenapartments.com/api/v1
#
# Console (admin.citydenapartments.com):
#   VITE_API_BASE_URL=https://api.citydenapartments.com/api/v1
#   VITE_PLATFORM_URL=https://staff.citydenapartments.com
